{
  "name": "dingtalk",
  "display_name": "DingTalk",
  "kind": "channel",
  "version": "0.1.0",
  "description": "DingTalk robot webhook channel",
  "keywords": ["messaging", "chat", "dingtalk", "robot"],
  "source": {

{
  "name": "matrix",
  "display_name": "Matrix",
  "kind": "channel",
  "version": "0.1.0",
  "description": "Matrix appservice/webhook channel for room messages",
  "keywords": ["messaging", "chat", "matrix", "room"],
  "source": {
    "dir": "channels-src/matrix",
    "capabilities": "matrix.capabilities.json",
    "crate_name": "matrix-channel"

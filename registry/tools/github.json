{
  "name": "github",
  "display_name": "GitHub",
  "kind": "tool",
  "version": "0.1.0",
  "description": "GitHub integration for issues, PRs, repos, and code search",
  "keywords": [
    "git",
    "code",
    "issues",
    "pull-requests",
    "repositories"
  ],
  "source": {
    "dir": "tools-src/github",
    "capabilities": "github-tool.capabilities.json",
    "crate_name": "github-tool"
  },
  "artifacts": {
    "wasm32-wasip2": {
      "url": "https://github.com/RNT56/ThinClaw/releases/download/v0.13.6/github-wasm32-wasip2.tar.gz",
      "sha256": "0e0c22ef436d195970c7d405f8f392a83b3179a99f22e99f742d2a395746f95b"
    }
  },
  "auth_summary": {
    "method": "manual",
    "provider": "GitHub",
    "secrets": [
      "github_token"
    ],
    "shared_auth": null,
    "setup_url": "https://github.com/settings/tokens"
  },
  "tags": [
    "default",
    "development"
  ]
}

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Least-privilege plugin capability for the main ThinClaw window",
  "windows": [
    "main"
  ],
  "permissions": [
    "opener:allow-default-urls",
    "core:event:default",
    "core:window:default",
    "fs:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$DOWNLOAD/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$DOWNLOAD/*"
        }
      ]
    },
    "updater:default",
    "process:default"
  ]
}

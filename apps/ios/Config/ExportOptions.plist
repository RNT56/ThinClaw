<?xml version="1.0" encoding="UTF-8"?>
<!--
  Export options for `xcodebuild -exportArchive` when cutting a TestFlight
  build (App Store Connect). No provisioning profiles are committed:
  distribution signing is resolved at export time via
  `-allowProvisioningUpdates` plus an App Store Connect API key.

  `teamID` is intentionally left as the `$(DEVELOPMENT_TEAM)` placeholder.
  Both the CI job and `scripts/archive.sh` substitute the operator's real
  team id (from a secret / Signing.local.xcconfig) into a working copy of
  this file before invoking `xcodebuild -exportArchive`. Nothing secret is
  committed here.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store</string>
	<key>destination</key>
	<string>export</string>
	<key>teamID</key>
	<string>$(DEVELOPMENT_TEAM)</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>manageAppVersionAndBuildNumber</key>
	<true/>
	<key>uploadSymbols</key>
	<true/>
	<key>stripSwiftSymbols</key>
	<true/>
	<key>generateAppStoreInformation</key>
	<true/>
</dict>
</plist>

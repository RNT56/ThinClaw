    "setup:ai": "node backend/scripts/download_ai_binaries.js",
    "setup:openclaw-engine": "cd backend/openclaw-engine && npm install --ignore-scripts",
    "setup:all": "npm run setup:node && npm run setup:chromium && npm run setup:ai && npm run setup:openclaw-engine"

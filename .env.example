# ═══════════════════════════════════════════════════════════════════════════════
# ThinClaw Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and edit the values.
# Run `thinclaw onboard` for interactive guided setup.
# Full provider reference: docs/LLM_PROVIDERS.md

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://localhost/thinclaw
# DATABASE_POOL_SIZE=10
# Default: libSQL (~/.thinclaw/thinclaw.db) — no config needed for local use.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Default backend: openai_compatible
# Possible values: openai, anthropic, gemini, tinfoil, ollama, bedrock,
#                  llama_cpp, openai_compatible

# === OpenRouter (recommended — 200+ models, one API key) ===
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-...
# LLM_MODEL=anthropic/claude-sonnet-4-20250514

# === Anthropic (direct API) ===
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# === OpenAI (direct API) ===
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...

# === Google Gemini ===
# LLM_BACKEND=gemini
# GEMINI_API_KEY=...

# === Tinfoil (private inference) ===
# LLM_BACKEND=tinfoil
# TINFOIL_API_KEY=...

# === Ollama (local) ===
# LLM_BACKEND=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434   # default

# === AWS Bedrock ===
# LLM_BACKEND=bedrock
# AWS_REGION=us-east-1
# BEDROCK_API_KEY=...

# === llama.cpp (local server) ===
# LLM_BACKEND=llama_cpp
# LLAMA_SERVER_URL=http://localhost:8080
# LLAMA_MODEL=llama-local

# === Groq (fast inference) ===
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# === DeepSeek ===
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=deepseek-chat

# === Together AI ===
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=...
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# === Fireworks AI ===
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_API_KEY=fw_...
# LLM_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic

# === Generic OpenAI-compatible (LM Studio, vLLM, LiteLLM, etc.) ===
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=sk-...                        # optional for local servers
# LLM_MODEL=llama-3.2-3b-instruct-q4_K_M

# Custom HTTP headers for OpenAI-compatible providers
# Format: comma-separated key:value pairs
# LLM_EXTRA_HEADERS=HTTP-Referer:https://github.com/RNT56/ThinClaw,X-Title:ThinClaw

# For full provider setup guide see docs/LLM_PROVIDERS.md

# ── Channels ──────────────────────────────────────────────────────────────────
# CLI is always enabled.

# Web Gateway (enabled by default on http://127.0.0.1:3000)
# GATEWAY_ENABLED=true
# GATEWAY_HOST=127.0.0.1
# GATEWAY_PORT=3000
# GATEWAY_AUTH_TOKEN=               # Bearer token for WebUI auth. Random 32-char token generated if unset.

# Telegram Bot (optional)
# TELEGRAM_BOT_TOKEN=...

# Slack Bot (optional)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...

# HTTP Webhook Server (optional)
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080
# HTTP_WEBHOOK_SECRET=your-webhook-secret

# Signal Channel (optional, requires signal-cli daemon --http)
# SIGNAL_HTTP_URL=http://127.0.0.1:8080
# SIGNAL_ACCOUNT=+1234567890
# SIGNAL_ALLOW_FROM=+1234567890,uuid:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # comma-separated, * for all, empty = deny/require pairing
# SIGNAL_ALLOW_FROM_GROUPS=                        # comma-separated group IDs, * for all, empty = deny all groups
# SIGNAL_DM_POLICY=pairing                         # open | allowlist | pairing
# SIGNAL_GROUP_POLICY=allowlist                     # allowlist | open | disabled
# SIGNAL_GROUP_ALLOW_FROM=                          # comma-separated, empty = inherit from ALLOW_FROM
# SIGNAL_IGNORE_ATTACHMENTS=false
# SIGNAL_IGNORE_STORIES=true

# Discord Channel (optional)
# DISCORD_ENABLED=true
# DISCORD_BOT_TOKEN=...
# DISCORD_GUILD_ID=                                 # restrict to single server (optional)
# DISCORD_ALLOW_FROM=                               # comma-separated channel IDs (empty = all)
# DISCORD_STREAM_MODE=edit                          # edit | status | (empty = disabled)

# BlueBubbles iMessage Bridge (optional, cross-platform)
# Connects to a BlueBubbles macOS server for iMessage from any platform.
# Requires: BlueBubbles Server v1.0+ running on a Mac.
# IMPORTANT: Use HTTPS (Cloudflare tunnel / Tailscale) for remote deployments —
# the BlueBubbles API sends the password as a query parameter.
# BLUEBUBBLES_ENABLED=false
# BLUEBUBBLES_SERVER_URL=http://192.168.1.50:1234   # your BlueBubbles server
# BLUEBUBBLES_PASSWORD=your-server-password
# BLUEBUBBLES_WEBHOOK_HOST=127.0.0.1                # webhook listen address (default: 127.0.0.1)
# BLUEBUBBLES_WEBHOOK_PORT=8645                      # webhook listen port (default: 8645)
# BLUEBUBBLES_WEBHOOK_PATH=/bluebubbles-webhook      # webhook URL path
# BLUEBUBBLES_ALLOW_FROM=+1234567890,user@icloud.com # comma-separated phone/email (empty = all)
# BLUEBUBBLES_SEND_READ_RECEIPTS=true                # requires Private API on server

# iMessage Channel (macOS only, native chat.db polling)
# IMESSAGE_ENABLED=false
# IMESSAGE_ALLOW_FROM=+1234567890,user@icloud.com   # comma-separated phone/email (empty = all)
# IMESSAGE_POLL_INTERVAL=3                           # seconds between chat.db checks

# Apple Mail Channel (macOS only)
# APPLE_MAIL_ENABLED=false
# APPLE_MAIL_ALLOW_FROM=                             # comma-separated sender emails (empty = all)
# APPLE_MAIL_POLL_INTERVAL=10                        # seconds between Envelope Index checks
# APPLE_MAIL_UNREAD_ONLY=true
# APPLE_MAIL_MARK_AS_READ=true

# ── Tunnel (for instant webhook delivery) ─────────────────────────────────────
# Without a tunnel, Telegram/Slack/Discord use polling (~5s latency).
# With a tunnel, they switch to instant webhook delivery (<200ms).
# See docs/DEPLOYMENT.md for full setup guide.
#
# TUNNEL_PROVIDER=tailscale                          # tailscale | ngrok | cloudflare | custom | none
# TUNNEL_URL=                                        # static URL (skips managed tunnel)
#
# Tailscale Funnel (recommended — free, persistent hostname, HTTPS included)
# macOS: install CLI first via Tailscale menubar → Install CLI
# TUNNEL_TS_FUNNEL=true                              # true = public Funnel (webhooks work)
# TUNNEL_TS_HOSTNAME=                                # override auto-detected hostname
#
# ngrok
# TUNNEL_NGROK_TOKEN=                                # auth token from dashboard.ngrok.com
# TUNNEL_NGROK_DOMAIN=                               # custom domain (paid plan)
#
# Cloudflare Tunnel
# TUNNEL_CF_TOKEN=                                   # tunnel token from Cloudflare Zero Trust

# ── Agent ─────────────────────────────────────────────────────────────────────
# AGENT_NAME=thinclaw
# AGENT_MAX_PARALLEL_JOBS=5
# AGENT_JOB_TIMEOUT_SECS=3600
# AGENT_STUCK_THRESHOLD_SECS=300
# AGENT_USE_PLANNING=true                           # Enable planning phase before tool execution (default: true)
# AGENT_CLI_SKIN=cockpit                            # Built-ins: cockpit, midnight, solar, athena, delphi, olympus

# Web gateway presentation
# WEBCHAT_THEME=system                              # system | light | dark
# WEBCHAT_SKIN=                                     # optional: override WebUI skin, else follows AGENT_CLI_SKIN
# WEBCHAT_ACCENT_COLOR=#22c55e                      # legacy accent-only override
# WEBCHAT_SHOW_BRANDING=true

# Self-repair settings
# SELF_REPAIR_CHECK_INTERVAL_SECS=60
# SELF_REPAIR_MAX_ATTEMPTS=3

# ── Heartbeat ─────────────────────────────────────────────────────────────────
# Proactive periodic execution. Reads HEARTBEAT.md checklist and reports findings.
# HEARTBEAT_ENABLED=false
# HEARTBEAT_INTERVAL_SECS=1800
# HEARTBEAT_NOTIFY_CHANNEL=cli
# HEARTBEAT_NOTIFY_USER=default

# ── Memory Hygiene ────────────────────────────────────────────────────────────
# Automatic cleanup of stale workspace documents. Runs on each heartbeat tick.
# Identity files (IDENTITY.md, SOUL.md) are never deleted.
# MEMORY_HYGIENE_ENABLED=true
# MEMORY_HYGIENE_RETENTION_DAYS=30
# MEMORY_HYGIENE_CADENCE_HOURS=12

# ── Safety ────────────────────────────────────────────────────────────────────
# SAFETY_MAX_OUTPUT_LENGTH=100000
# SAFETY_INJECTION_CHECK_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
# RUST_LOG=thinclaw=debug,tower_http=debug

{
  "type": "channel",
  "name": "line",
  "description": "LINE Messaging API webhook channel",
  "formatting_hints": "LINE messages render best as short plain text. Avoid tables and long code blocks.",
  "setup": {
    "required_secrets": [
      {
        "name": "line_channel_access_token",
        "prompt": "Enter your LINE channel access token",
        "optional": false
      },
      {
        "name": "line_channel_secret",
        "prompt": "Enter your LINE channel secret",
        "optional": false
      }
    ]
  },
  "capabilities": {
    "http": {
      "allowlist": [
        {
          "host": "api.line.me",
          "path_prefix": "/v2/bot/"
        }
      ],
      "credentials": {
        "line_channel_access_token": {
          "secret_name": "line_channel_access_token",
          "location": {
            "type": "bearer"
          },
          "host_patterns": [
            "api.line.me"
          ]
        }
      },
      "rate_limit": {
        "requests_per_minute": 60,
        "requests_per_hour": 3000
      }
    },
    "secrets": {
      "allowed_names": [
        "line_*"
      ]
    },
    "channel": {
      "allowed_paths": [
        "/webhook/line"
      ],
      "allow_polling": false,
      "workspace_prefix": "channels/line/",
      "emit_rate_limit": {
        "messages_per_minute": 60,
        "messages_per_hour": 3000
      },
      "webhook": {
        "secret_header": "X-Line-Signature",
        "secret_name": "line_channel_secret",
        "secret_validation": "hmac_sha256_base64_body"
      }
    }
  },
  "config": {
    "channel_name": "line",
    "display_name": "LINE",
    "webhook_path": "/webhook/line",
    "mapping": {
      "text": [
        "message.text"
      ],
      "user_id": [
        "source.userId"
      ],
      "user_name": [
        "source.userId"
      ],
      "chat_id": [
        "source.groupId",
        "source.roomId",
        "source.userId"
      ],
      "chat_type": [
        "source.type"
      ],
      "message_id": [
        "message.id"
      ],
      "metadata": {
        "reply_token": [
          "replyToken"
        ]
      }
    },
    "response": {
      "url": "https://api.line.me/v2/bot/message/reply",
      "method": "POST",
      "body_format": "json",
      "body": {
        "replyToken": "{reply_token}",
        "messages": [
          {
            "type": "text",
            "text": "{content}"
          }
        ]
      },
      "headers": {
        "Authorization": "Bearer {LINE_CHANNEL_ACCESS_TOKEN}"
      }
    },
    "events_path": "events"
  }
}

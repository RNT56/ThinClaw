{
  "type": "channel",
  "name": "line",
  "description": "LINE Messaging API webhook channel",
  "formatting_hints": "LINE messages render best as short plain text. Avoid tables and long code blocks.",
  "setup": {
    "required_secrets": [
      { "name": "line_channel_access_token", "prompt": "Enter your LINE channel access token", "optional": false },
      { "name": "line_channel_secret", "prompt": "Enter your LINE channel secret", "optional": false }
    ]
  },
  "capabilities": {
    "http": {
      "allowlist": [{ "host": "api.line.me", "path_prefix": "/v2/bot/" }],
      "credentials": {
        "line_channel_access_token": {
          "secret_name": "line_channel_access_token",
          "location": { "type": "bearer" },
          "host_patterns": ["api.line.me"]
        }
      },
      "rate_limit": { "requests_per_minute": 60, "requests_per_hour": 3000 }
    },
    "secrets": { "allowed_names": ["line_*"] },
    "channel": {
      "allowed_paths": ["/webhook/line"],
      "allow_polling": false,
      "workspace_prefix": "channels/line/",
      "emit_rate_limit": { "messages_per_minute": 60, "messages_per_hour": 3000 }
    }
  },
  "config": {
    "channel_name": "line",
    "display_name": "LINE",
    "webhook_path": "/webhook/line",
    "mapping": {
      "text": ["events[0].message.text", "message.text", "text"],
      "user_id": ["events[0].source.userId", "source.userId", "user_id"],
      "user_name": ["events[0].source.userId", "user.name"],
      "chat_id": ["events[0].source.groupId", "events[0].source.roomId", "events[0].source.userId", "chat_id"],
      "chat_type": ["events[0].source.type", "chat_type"],
      "message_id": ["events[0].message.id"]
    },
    "response": {
      "url": "https://api.line.me/v2/bot/message/push",
      "method": "POST",
      "body_format": "json",
      "body": { "to": "{chat_id}", "messages": "{content}" }
    }
  }
}

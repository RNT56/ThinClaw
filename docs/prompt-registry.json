{
  "contract_version": "v2",
  "entries": [
    {
      "id": "canonical_compiler",
      "owner": "llm-core",
      "consumer": "all provider-backed agent surfaces",
      "authority": "typed PromptTrust",
      "lifetime": "typed PromptLifetime",
      "input_provenance": "registered PromptSegment sources",
      "output_contract": "CompiledPrompt",
      "token_policy": "global PromptBudget",
      "parser": "typed compiler",
      "model_capabilities": "provider-neutral",
      "test_owner": "thinclaw-llm-core prompt_contract tests",
      "paths": ["crates/thinclaw-llm-core/src/prompt_contract.rs", "crates/thinclaw-agent/src/prompt_assembly.rs"]
    },
    {
      "id": "main_dispatcher",
      "owner": "agent-runtime",
      "consumer": "interactive agent loop",
      "authority": "policy and trusted configuration plus user-role evidence",
      "lifetime": "stable and per-turn",
      "input_provenance": "workspace, skills, runtime, recall, conversation",
      "output_contract": "native tool calls or final text",
      "token_policy": "PromptSettings global budget",
      "parser": "provider tool protocol",
      "model_capabilities": "native tools, streaming, reasoning",
      "test_owner": "dispatcher and reasoning tests",
      "path_prefixes": ["src/agent/", "crates/thinclaw-agent/src/"]
    },
    {
      "id": "workspace_personality_skills",
      "owner": "workspace-runtime",
      "consumer": "main, workers, subagents, routines",
      "authority": "trusted user configuration below immutable policy",
      "lifetime": "stable with turn overlays",
      "input_provenance": "workspace markdown and installed skill metadata",
      "output_contract": "named prompt sections",
      "token_policy": "section-aware extraction plus global compiler",
      "parser": "markdown section parser",
      "model_capabilities": "provider-neutral",
      "test_owner": "workspace_core and prompt assembly tests",
      "path_prefixes": ["crates/thinclaw-workspace/src/", "crates/thinclaw-soul/src/", "assets/personality_packs/"]
    },
    {
      "id": "desktop_direct",
      "owner": "desktop-runtime",
      "consumer": "desktop direct, vision, RAG and Rhai tool loops",
      "authority": "canonical compiler with untrusted RAG and tool evidence",
      "lifetime": "stable persona and turn context",
      "input_provenance": "desktop persona, user turn, RAG, images, sandbox",
      "output_contract": "provider events and final text",
      "token_policy": "desktop PromptBudget and hard tool-round cap",
      "parser": "provider stream and Rhai tags",
      "model_capabilities": "vision, local/cloud completion, Rhai tools",
      "test_owner": "desktop backend and frontend tests",
      "path_prefixes": ["apps/desktop/backend/src/rig_lib/", "apps/desktop/frontend/src/lib/prompt-enhancer.ts", "apps/desktop/frontend/src/components/thinclaw/"]
    },
    {
      "id": "workers_subagents_advisor",
      "owner": "agent-runtime",
      "consumer": "workers, delegated agents and advisor",
      "authority": "one trusted mission wrapper with bounded task/evidence",
      "lifetime": "per job or delegated task",
      "input_provenance": "orchestrator task packet and scoped grants",
      "output_contract": "complete_job or strict role schema",
      "token_policy": "bounded task packets and iteration caps",
      "parser": "tool protocol or strict JSON with one repair where supported",
      "model_capabilities": "tools and schema output",
      "test_owner": "worker, subagent and advisor tests",
      "path_prefixes": ["src/agent/worker.rs", "src/agent/subagent_executor/", "src/agent/dispatcher/advisor.rs", "crates/thinclaw-agent/src/worker_runtime.rs", "crates/thinclaw-tools/src/builtin/subagent.rs", "crates/thinclaw-tools/src/builtin/advisor.rs"]
    },
    {
      "id": "routines_heartbeat",
      "owner": "agent-runtime",
      "consumer": "scheduled routines and heartbeat",
      "authority": "trusted checker policy with untrusted state and trigger evidence",
      "lifetime": "per run",
      "input_provenance": "checklist, state, daily logs and trigger payload",
      "output_contract": "typed heartbeat or routine JSON",
      "token_policy": "bounded context and explicit output cap",
      "parser": "exact serde JSON, fail closed",
      "model_capabilities": "text or schema output",
      "test_owner": "heartbeat and routine_engine tests",
      "path_prefixes": ["crates/thinclaw-agent/src/heartbeat.rs", "crates/thinclaw-agent/src/routine_engine.rs", "src/agent/routine_engine/"]
    },
    {
      "id": "secondary_evaluators",
      "owner": "agent-quality",
      "consumer": "compaction, search, evaluation, outcomes and MoA",
      "authority": "trusted evaluator policy plus untrusted evidence",
      "lifetime": "per evaluation",
      "input_provenance": "conversation, tool output, candidates and job records",
      "output_contract": "bounded summary, final text or typed JSON",
      "token_policy": "small explicit output caps",
      "parser": "strict JSON for machine consumers",
      "model_capabilities": "text and optional schema output",
      "test_owner": "compaction, evaluation, search and tool tests",
      "path_prefixes": ["src/agent/compaction.rs", "src/evaluation/", "crates/thinclaw-agent/src/session_search.rs", "crates/thinclaw-agent/src/outcomes.rs", "crates/thinclaw-tools/src/builtin/moa.rs"]
    },
    {
      "id": "repo_research_builder",
      "owner": "repo-projects and research",
      "consumer": "coding backends and experiment roles",
      "authority": "trusted operating wrapper plus untrusted repository evidence",
      "lifetime": "per packet or trial",
      "input_provenance": "issues, CI, diffs, worktrees and experiment plans",
      "output_contract": "artifacts and strict role JSON",
      "token_policy": "bounded diff/evidence previews",
      "parser": "strict role schema",
      "model_capabilities": "file tools and JSON",
      "test_owner": "repo_projects and experiments tests",
      "path_prefixes": ["src/repo_projects/", "src/api/experiments/", "src/tools/builder/"]
    },
    {
      "id": "tool_schemas_and_approval",
      "owner": "tool-runtime",
      "consumer": "all tool-capable agents",
      "authority": "schemas are canonical; LLM security triage cannot approve",
      "lifetime": "registry stable plus per-call evidence",
      "input_provenance": "tool implementation and untrusted arguments",
      "output_contract": "tool schema or deny/escalate JSON",
      "token_policy": "compact native schemas and 96-token security response",
      "parser": "tool protocol and exact deny/escalate JSON",
      "model_capabilities": "native tools or generated code-mode cards",
      "test_owner": "thinclaw-tools tests",
      "path_prefixes": ["crates/thinclaw-tools/src/", "src/tools/"]
    },
    {
      "id": "provider_transport",
      "owner": "llm-runtime",
      "consumer": "provider adapters and compatibility APIs",
      "authority": "transport only; no authority promotion",
      "lifetime": "per request",
      "input_provenance": "CompiledPrompt and ChatMessage",
      "output_contract": "provider request/response DTOs",
      "token_policy": "request budget supplied by caller",
      "parser": "provider protocol",
      "model_capabilities": "provider-specific transport",
      "test_owner": "provider adapter tests",
      "path_prefixes": ["src/llm/", "crates/thinclaw-llm/src/", "crates/thinclaw-llm-core/src/", "crates/thinclaw-gateway/src/", "src/channels/web/", "crates/thinclaw-gateway/src/web/"]
    },
    {
      "id": "registry_and_persistence",
      "owner": "agent-platform",
      "consumer": "agent registry, runtime persistence and profile helpers",
      "authority": "stored configuration below immutable policy",
      "lifetime": "persistent",
      "input_provenance": "database and operator configuration",
      "output_contract": "serialized prompt metadata",
      "token_policy": "content-free telemetry only",
      "parser": "serde DTOs",
      "model_capabilities": "provider-neutral",
      "test_owner": "registry and persistence tests",
      "path_prefixes": ["crates/thinclaw-agent/src/agent_registry.rs", "crates/thinclaw-db/src/", "src/profile.rs", "src/worker/", "apps/desktop/backend/src/thinclaw/"]
    }
  ]
}

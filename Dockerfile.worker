# Multi-stage Dockerfile for the ThinClaw worker container.
#
# This image runs the thinclaw binary in worker mode inside Docker containers.
# The orchestrator creates instances of this image for sandboxed job execution.
#
# Build:
#   docker build -f Dockerfile.worker -t thinclaw-worker .
#
# The image includes common development tools so workers can build software,
# run tests, and execute shell commands.

FROM rust:1.92-bookworm AS builder

WORKDIR /build
COPY . .

# Build the worker binary with Docker sandbox support enabled so the
# container entrypoints expose the internal bridge subcommands.
RUN cargo build --release --features docker-sandbox --bin thinclaw

# ---

FROM debian:bookworm-slim

# Install curl first (needed to fetch the GitHub CLI GPG key), then add the
# gh CLI apt repository, then install all remaining dev tools in one layer.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    pkg-config \
    libssl-dev \
    nodejs \
    npm \
    python3 \
    python3-pip \
    python3-venv \
    gh \
    && rm -rf /var/lib/apt/lists/*

# Install Rust toolchain for the sandbox user
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    CODEX_HOME=/home/sandbox/.codex \
    PATH=/usr/local/cargo/bin:$PATH
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.92.0 \
    && chmod -R a+r /usr/local/rustup /usr/local/cargo

# Install container coding CLIs (for claude-bridge and codex-bridge modes)
RUN npm install -g @anthropic-ai/claude-code@latest @openai/codex@latest

# Copy the binary
COPY --from=builder /build/target/release/thinclaw /usr/local/bin/thinclaw

# Create non-root user (UID 1000 matches the orchestrator's container config)
RUN useradd -m -u 1000 -s /bin/bash sandbox \
    && mkdir -p /workspace \
    && chown sandbox:sandbox /workspace \
    && mkdir -p /home/sandbox/.claude \
    && mkdir -p /home/sandbox/.codex \
    && chown sandbox:sandbox /home/sandbox/.claude /home/sandbox/.codex

USER sandbox
WORKDIR /workspace

# Health check: the entrypoint script touches a sentinel file on start.
# If the main process dies, the file is stale; this is sufficient for
# Docker to mark the container as unhealthy for the orphan reaper.
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD test -f /tmp/.thinclaw-alive || exit 1

# The orchestrator passes the full command via Docker cmd.
# The wrapper script touches the sentinel before exec-ing thinclaw.
COPY --chmod=755 <<'EOF' /usr/local/bin/entrypoint.sh
#!/bin/bash
touch /tmp/.thinclaw-alive
exec thinclaw "$@"
EOF

ENTRYPOINT ["entrypoint.sh"]

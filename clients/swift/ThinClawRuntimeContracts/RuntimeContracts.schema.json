{
  "components": {
    "schemas": {
      "ApiStyle": {
        "description": "API compatibility mode for a cloud provider.",
        "oneOf": [
          {
            "const": "openai",
            "description": "Native OpenAI API.",
            "type": "string"
          },
          {
            "const": "anthropic",
            "description": "Native Anthropic API.",
            "type": "string"
          },
          {
            "const": "openai_compatible",
            "description": "OpenAI-compatible endpoint.",
            "type": "string"
          },
          {
            "const": "ollama",
            "description": "Local Ollama-compatible runtime.",
            "type": "string"
          }
        ]
      },
      "AssetKind": {
        "enum": [
          "image",
          "audio",
          "video",
          "document",
          "generated_image",
          "other"
        ],
        "type": "string"
      },
      "AssetNamespace": {
        "enum": [
          "direct_workbench",
          "thin_claw_agent"
        ],
        "type": "string"
      },
      "AssetOrigin": {
        "enum": [
          "upload",
          "generated",
          "downloaded_model_output",
          "voice_input",
          "voice_output",
          "rag_document"
        ],
        "type": "string"
      },
      "AssetRecord": {
        "properties": {
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "height": {
            "default": null,
            "format": "uint32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "kind": {
            "$ref": "#/components/schemas/AssetKind"
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "default": {},
            "type": "object"
          },
          "mimeType": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "origin": {
            "$ref": "#/components/schemas/AssetOrigin"
          },
          "path": {
            "type": "string"
          },
          "prompt": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "provider": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "reference": {
            "$ref": "#/components/schemas/AssetRef"
          },
          "sha256": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "sizeBytes": {
            "default": null,
            "format": "uint64",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/AssetStatus"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "visibility": {
            "$ref": "#/components/schemas/AssetVisibility"
          },
          "width": {
            "default": null,
            "format": "uint32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "reference",
          "kind",
          "origin",
          "status",
          "visibility",
          "path",
          "createdAt",
          "updatedAt"
        ],
        "type": "object"
      },
      "AssetRef": {
        "properties": {
          "id": {
            "type": "string"
          },
          "namespace": {
            "$ref": "#/components/schemas/AssetNamespace"
          }
        },
        "required": [
          "namespace",
          "id"
        ],
        "type": "object"
      },
      "AssetStatus": {
        "enum": [
          "ready",
          "pending",
          "deleted",
          "error"
        ],
        "type": "string"
      },
      "AssetVisibility": {
        "enum": [
          "private",
          "shared_by_explicit_handoff"
        ],
        "type": "string"
      },
      "DirectAttachedDocument": {
        "properties": {
          "assetRef": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AssetRef"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ],
        "type": "object"
      },
      "DirectChatMessage": {
        "properties": {
          "assets": {
            "default": null,
            "items": {
              "$ref": "#/components/schemas/AssetRef"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "attachedDocs": {
            "default": null,
            "items": {
              "$ref": "#/components/schemas/DirectAttachedDocument"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "content": {
            "type": "string"
          },
          "images": {
            "default": null,
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "isSummary": {
            "default": null,
            "type": [
              "boolean",
              "null"
            ]
          },
          "originalMessages": {
            "default": null,
            "items": {
              "$ref": "#/components/schemas/DirectChatMessage"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "role",
          "content"
        ],
        "type": "object"
      },
      "DirectChatPayload": {
        "properties": {
          "autoMode": {
            "default": false,
            "type": "boolean"
          },
          "conversationId": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/DirectChatMessage"
            },
            "type": "array"
          },
          "model": {
            "type": "string"
          },
          "projectId": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "temperature": {
            "format": "float",
            "type": "number"
          },
          "topP": {
            "format": "float",
            "type": "number"
          },
          "webSearchEnabled": {
            "default": false,
            "type": "boolean"
          }
        },
        "required": [
          "model",
          "messages",
          "temperature",
          "topP"
        ],
        "type": "object"
      },
      "DirectConversation": {
        "properties": {
          "createdAt": {
            "format": "int64",
            "type": "integer"
          },
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updatedAt": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "title",
          "createdAt",
          "updatedAt"
        ],
        "type": "object"
      },
      "DirectDocumentIngestResponse": {
        "properties": {
          "asset": {
            "$ref": "#/components/schemas/AssetRecord"
          },
          "documentId": {
            "type": "string"
          }
        },
        "required": [
          "documentId",
          "asset"
        ],
        "type": "object"
      },
      "DirectDocumentUploadResponse": {
        "properties": {
          "asset": {
            "$ref": "#/components/schemas/AssetRecord"
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "asset"
        ],
        "type": "object"
      },
      "DirectStreamChunk": {
        "properties": {
          "content": {
            "type": "string"
          },
          "contextUpdate": {
            "default": null,
            "items": {
              "$ref": "#/components/schemas/DirectChatMessage"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "done": {
            "type": "boolean"
          },
          "usage": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DirectTokenUsage"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          }
        },
        "required": [
          "content",
          "done"
        ],
        "type": "object"
      },
      "DirectSttResponse": {
        "properties": {
          "asset": {
            "$ref": "#/components/schemas/AssetRecord"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text",
          "asset"
        ],
        "type": "object"
      },
      "DirectTokenUsage": {
        "properties": {
          "completionTokens": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          },
          "promptTokens": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          },
          "totalTokens": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "promptTokens",
          "completionTokens",
          "totalTokens"
        ],
        "type": "object"
      },
      "DirectTtsResponse": {
        "properties": {
          "asset": {
            "$ref": "#/components/schemas/AssetRecord"
          },
          "audioBytes": {
            "description": "Base64-encoded audio bytes for existing web audio playback flows.",
            "type": "string"
          }
        },
        "required": [
          "audioBytes",
          "asset"
        ],
        "type": "object"
      },
      "LocalRuntimeEndpoint": {
        "properties": {
          "apiKey": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "baseUrl": {
            "type": "string"
          },
          "contextSize": {
            "default": null,
            "format": "uint32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "modelFamily": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "modelId": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "baseUrl"
        ],
        "type": "object"
      },
      "LocalRuntimeKind": {
        "enum": [
          "llama_cpp",
          "mlx",
          "vllm",
          "ollama",
          "none"
        ],
        "type": "string"
      },
      "LocalRuntimeSnapshot": {
        "properties": {
          "capabilities": {
            "default": [],
            "description": "Capabilities that are active and ready in the current runtime snapshot.",
            "items": {
              "$ref": "#/components/schemas/RuntimeCapability"
            },
            "type": "array"
          },
          "displayName": {
            "type": "string"
          },
          "endpoint": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/LocalRuntimeEndpoint"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "exposurePolicy": {
            "$ref": "#/components/schemas/RuntimeExposurePolicy"
          },
          "kind": {
            "$ref": "#/components/schemas/LocalRuntimeKind"
          },
          "readiness": {
            "$ref": "#/components/schemas/RuntimeReadiness"
          },
          "supportedCapabilities": {
            "default": [],
            "description": "Capabilities this runtime family can support when the relevant local\nservices are configured and running.",
            "items": {
              "$ref": "#/components/schemas/RuntimeCapability"
            },
            "type": "array"
          },
          "unavailableReason": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "kind",
          "displayName",
          "readiness",
          "exposurePolicy"
        ],
        "type": "object"
      },
      "ModelCapabilitySet": {
        "properties": {
          "jsonMode": {
            "type": "boolean"
          },
          "streaming": {
            "type": "boolean"
          },
          "systemPrompt": {
            "type": "boolean"
          },
          "thinking": {
            "type": "boolean"
          },
          "tools": {
            "type": "boolean"
          },
          "vision": {
            "type": "boolean"
          }
        },
        "required": [
          "streaming",
          "tools",
          "vision",
          "thinking",
          "jsonMode",
          "systemPrompt"
        ],
        "type": "object"
      },
      "ModelCategory": {
        "enum": [
          "chat",
          "embedding",
          "tts",
          "stt",
          "diffusion",
          "other"
        ],
        "type": "string"
      },
      "ModelDescriptor": {
        "properties": {
          "capabilities": {
            "$ref": "#/components/schemas/ModelCapabilitySet",
            "default": {
              "jsonMode": false,
              "streaming": false,
              "systemPrompt": false,
              "thinking": false,
              "tools": false,
              "vision": false
            }
          },
          "category": {
            "$ref": "#/components/schemas/ModelCategory"
          },
          "contextWindow": {
            "default": null,
            "format": "uint32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "deprecated": {
            "default": false,
            "type": "boolean"
          },
          "displayName": {
            "type": "string"
          },
          "embeddingDimensions": {
            "default": null,
            "format": "uint32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "maxOutputTokens": {
            "default": null,
            "format": "uint32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "default": {},
            "type": "object"
          },
          "pricing": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ModelPricing"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "provider": {
            "type": "string"
          },
          "providerName": {
            "type": "string"
          },
          "supportsStreaming": {
            "default": false,
            "type": "boolean"
          },
          "supportsTools": {
            "default": false,
            "type": "boolean"
          },
          "supportsVision": {
            "default": false,
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "displayName",
          "provider",
          "providerName",
          "category"
        ],
        "type": "object"
      },
      "ModelDiscoveryResult": {
        "properties": {
          "errors": {
            "default": [],
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "providers": {
            "items": {
              "$ref": "#/components/schemas/ProviderDiscoveryResult"
            },
            "type": "array"
          },
          "totalModels": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "providers",
          "totalModels"
        ],
        "type": "object"
      },
      "ModelPricing": {
        "properties": {
          "inputPerMillion": {
            "format": "double",
            "type": [
              "number",
              "null"
            ]
          },
          "outputPerMillion": {
            "format": "double",
            "type": [
              "number",
              "null"
            ]
          },
          "per1kChars": {
            "format": "double",
            "type": [
              "number",
              "null"
            ]
          },
          "perImage": {
            "format": "double",
            "type": [
              "number",
              "null"
            ]
          },
          "perMinute": {
            "format": "double",
            "type": [
              "number",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "ProviderCredentialDescriptor": {
        "description": "Provider credential metadata safe to expose to clients.",
        "properties": {
          "credentialReady": {
            "default": false,
            "type": "boolean"
          },
          "displayName": {
            "type": "string"
          },
          "envKeyName": {
            "type": "string"
          },
          "providerSlug": {
            "type": "string"
          },
          "secretName": {
            "type": "string"
          },
          "setupUrl": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "providerSlug",
          "displayName",
          "secretName",
          "envKeyName"
        ],
        "type": "object"
      },
      "ProviderDiscoveryResult": {
        "properties": {
          "error": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "fromCache": {
            "type": "boolean"
          },
          "models": {
            "items": {
              "$ref": "#/components/schemas/ModelDescriptor"
            },
            "type": "array"
          },
          "provider": {
            "type": "string"
          }
        },
        "required": [
          "provider",
          "models",
          "fromCache"
        ],
        "type": "object"
      },
      "ProviderEndpoint": {
        "description": "Endpoint configuration for a cloud provider.",
        "properties": {
          "api_style": {
            "$ref": "#/components/schemas/ApiStyle"
          },
          "base_url": {
            "type": "string"
          },
          "default_context_size": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          },
          "default_model": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "env_key_name": {
            "type": "string"
          },
          "id": {
            "description": "Provider slug, serialized as `id` in the registry.",
            "type": "string"
          },
          "notes": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "secret_name": {
            "type": "string"
          },
          "setup_url": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "suggested_cheap_model": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "supports_streaming": {
            "type": "boolean"
          },
          "tier": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "display_name",
          "base_url",
          "api_style",
          "default_model",
          "default_context_size",
          "supports_streaming",
          "env_key_name",
          "secret_name"
        ],
        "type": "object"
      },
      "RuntimeCapability": {
        "enum": [
          "chat",
          "embedding",
          "tts",
          "stt",
          "diffusion"
        ],
        "type": "string"
      },
      "RuntimeExposurePolicy": {
        "enum": [
          "direct_only",
          "shared_when_enabled",
          "network_exposed"
        ],
        "type": "string"
      },
      "RuntimeReadiness": {
        "enum": [
          "ready",
          "starting",
          "setup_required",
          "unavailable"
        ],
        "type": "string"
      },
      "SecretConsumer": {
        "description": "Runtime family requesting secret access.",
        "enum": [
          "direct_workbench",
          "thin_claw_agent",
          "gateway_proxy",
          "extension",
          "system"
        ],
        "type": "string"
      },
      "SecretDescriptor": {
        "description": "Canonical secret identity plus compatibility aliases.",
        "properties": {
          "allowedConsumers": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/SecretConsumer"
            },
            "type": "array"
          },
          "canonicalName": {
            "type": "string"
          },
          "envKeyName": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          },
          "legacyAliases": {
            "default": [],
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "providerSlug": {
            "default": null,
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "canonicalName"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "title": "ThinClaw Runtime Contracts",
    "version": "0.1.0"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "openapi": "3.1.0"
}

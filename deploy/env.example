# IronClaw — Example Environment Configuration
#
# Copy this file to ~/.ironclaw/.env (for direct binary)
# or to deploy/.env (for Docker Compose).
#
# WARNING: Replace all CHANGE_ME values before deploying.
# Generate a secure token: openssl rand -hex 32

# ── LLM Provider (choose one) ───────────────────────────────────────────────

# Anthropic (Claude)
LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=CHANGE_ME

# OpenAI
# LLM_BACKEND=openai
# OPENAI_API_KEY=CHANGE_ME

# OpenRouter (multi-provider — 300+ models via single key)
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=CHANGE_ME
# LLM_MODEL=anthropic/claude-sonnet-4-5

# Ollama (local inference)
# LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ── Gateway (required for Scrappy connection) ────────────────────────────────

GATEWAY_ENABLED=true
# Use 0.0.0.0 for remote access, 127.0.0.1 for local-only
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=18789
GATEWAY_AUTH_TOKEN=CHANGE_ME

# ── Database ─────────────────────────────────────────────────────────────────

# LibSQL (recommended — zero dependencies, auto-created)
DATABASE_BACKEND=libsql
LIBSQL_PATH=~/.ironclaw/ironclaw.db

# PostgreSQL (production)
# DATABASE_BACKEND=postgres
# DATABASE_URL=postgres://ironclaw:CHANGE_ME@localhost:5432/ironclaw

# ── Agent ────────────────────────────────────────────────────────────────────

AGENT_NAME=ironclaw
CLI_ENABLED=true
AGENT_AUTO_APPROVE_TOOLS=false

# ── Embeddings ───────────────────────────────────────────────────────────────

EMBEDDING_ENABLED=false
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=CHANGE_ME

# ── Channels (optional) ─────────────────────────────────────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_OWNER_ID=12345678

# Discord
# DISCORD_BOT_TOKEN=...
# DISCORD_GUILD_ID=...

# iMessage (macOS only)
# IMESSAGE_ALLOW_FROM=+1234567890

# Signal (requires signal-cli REST API)
# SIGNAL_HTTP_URL=http://localhost:8080
# SIGNAL_ALLOW_FROM=+1234567890

# ── Optional Features ────────────────────────────────────────────────────────

SANDBOX_ENABLED=false
HEARTBEAT_ENABLED=false
ROUTINES_ENABLED=true

# Brave Search (for web_search tool)
# BRAVE_SEARCH_API_KEY=BSA...

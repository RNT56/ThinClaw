# ThinClaw — Example Environment Configuration
#
# Copy this file to ~/.thinclaw/.env (for direct binary)
# or to deploy/.env (for Docker Compose deployment).
#
# Required: at least one LLM provider + gateway token for remote access.
# See docs/DEPLOYMENT.md for full reference.
#
# Raspberry Pi OS Lite Docker quick start:
#   cp env.example .env
#   sed -i "s/^GATEWAY_AUTH_TOKEN=.*/GATEWAY_AUTH_TOKEN=$(openssl rand -hex 32)/" .env
#   docker compose pull thinclaw
#   docker compose up -d

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose ONE backend and provide the corresponding API key:

# OpenRouter (recommended — 200+ models, one API key)
LLM_BACKEND=openai_compatible
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-CHANGE_ME
LLM_MODEL=anthropic/claude-sonnet-4-20250514

# Anthropic (Claude)
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-CHANGE_ME

# OpenAI
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-CHANGE_ME

# Ollama (local inference)
# LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_BACKEND=libsql
LIBSQL_PATH=~/.thinclaw/thinclaw.db

# PostgreSQL (production)
# DATABASE_BACKEND=postgres
# DATABASE_URL=postgres://thinclaw:CHANGE_ME@localhost:5432/thinclaw

# ── Gateway (required for Scrappy remote connection) ─────────────────────────
GATEWAY_ENABLED=true
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3000
GATEWAY_AUTH_TOKEN=CHANGE_ME_USE_openssl_rand_hex_32

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_NAME=thinclaw
CLI_ENABLED=false
THINCLAW_RUNTIME_PROFILE=pi-os-lite-64
THINCLAW_HEADLESS=true

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_ENABLED=true
EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...  (shared with LLM if using OpenAI backend)

# ── Optional Features ────────────────────────────────────────────────────────
# Docker image/build profile for Compose. Raspberry Pi OS Lite should pull the
# multi-arch GHCR image instead of building on-device when possible.
THINCLAW_IMAGE=ghcr.io/rnt56/thinclaw:latest
BUILD_FEATURES=full
HEARTBEAT_ENABLED=false
SANDBOX_ENABLED=false
ROUTINES_ENABLED=true

# Browser automation fallback. auto = local browser first, Docker Chromium second.
BROWSER_DOCKER=auto
CHROMIUM_IMAGE=chromedp/headless-shell:latest
# BROWSER_EXECUTABLE=/usr/bin/google-chrome-stable

# Privacy-sensitive local device tools remain opt-in.
SCREEN_CAPTURE_ENABLED=false
CAMERA_CAPTURE_ENABLED=false
TALK_MODE_ENABLED=false
LOCATION_ENABLED=false
LOCATION_ALLOW_IP_FALLBACK=false
DESKTOP_AUTONOMY_ENABLED=false
# Optional Linux device/backend overrides.
# THINCLAW_CAMERA_DEVICE=/dev/video0
# THINCLAW_MICROPHONE_DEVICE=default
THINCLAW_MICROPHONE_BACKEND=auto

# Headless/container secrets fallback. Prefer service-manager secrets.
# THINCLAW_ALLOW_ENV_MASTER_KEY=1
# SECRETS_MASTER_KEY=hex-encoded-32-byte-key
